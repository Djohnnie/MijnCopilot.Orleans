@using System.Security.Claims

@page "/profile"
@attribute [Authorize]

<PageTitle>Profiel</PageTitle>

<AuthorizeView>
    <Authorized>
        <MudContainer MaxWidth="MaxWidth.Small" Class="mt-8 mb-8">

            @* ---- Avatar & identity ---- *@
            <MudStack AlignItems="AlignItems.Center" Spacing="2" Class="mb-8">
                <MudAvatar Style="width: 96px; height: 96px;">
                    <img src="@context.User.FindFirst("picture")?.Value" alt="Profielfoto"
                         style="width:100%;height:100%;object-fit:cover;border-radius:inherit;" />
                </MudAvatar>
                <MudText Typo="Typo.h4" Style="font-weight: 700; margin-top: 8px;">
                    @context.User.FindFirst("nickname")?.Value
                </MudText>
                <MudText Typo="Typo.body2" Color="Color.Secondary">
                    @context.User.FindFirst("email")?.Value
                </MudText>
            </MudStack>

            @* ---- Info rows ---- *@
            <MudStack Spacing="3" Class="mb-6">
                <MudPaper Elevation="0" Class="pa-4"
                          Style="border: 1px solid var(--mud-palette-lines-default); border-radius: 12px;">
                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="3">
                        <div style="width: 40px; height: 40px; border-radius: 10px; background: var(--mud-palette-primary); flex-shrink: 0; display: flex; align-items: center; justify-content: center;">
                            <MudIcon Icon="@Icons.Material.Filled.Person" Style="color: white;" />
                        </div>
                        <MudStack Spacing="0">
                            <MudText Typo="Typo.caption" Color="Color.Secondary">Volledige naam</MudText>
                            <MudText Typo="Typo.body1">@context.User.Identity?.Name</MudText>
                        </MudStack>
                    </MudStack>
                </MudPaper>

                <MudPaper Elevation="0" Class="pa-4"
                          Style="border: 1px solid var(--mud-palette-lines-default); border-radius: 12px;">
                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="3">
                        <div style="width: 40px; height: 40px; border-radius: 10px; background: var(--mud-palette-primary); flex-shrink: 0; display: flex; align-items: center; justify-content: center;">
                            <MudIcon Icon="@Icons.Material.Filled.Email" Style="color: white;" />
                        </div>
                        <MudStack Spacing="0">
                            <MudText Typo="Typo.caption" Color="Color.Secondary">E-mailadres</MudText>
                            <MudText Typo="Typo.body1">@context.User.FindFirst("email")?.Value</MudText>
                        </MudStack>
                    </MudStack>
                </MudPaper>

                <MudPaper Elevation="0" Class="pa-4"
                          Style="border: 1px solid var(--mud-palette-lines-default); border-radius: 12px;">
                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="3">
                        <div style="width: 40px; height: 40px; border-radius: 10px; background: var(--mud-palette-primary); flex-shrink: 0; display: flex; align-items: center; justify-content: center;">
                            <MudIcon Icon="@Icons.Material.Filled.Badge" Style="color: white;" />
                        </div>
                        <MudStack Spacing="0" Style="min-width: 0;">
                            <MudText Typo="Typo.caption" Color="Color.Secondary">Account ID</MudText>
                            <MudText Typo="Typo.body2" Style="font-family: monospace; word-break: break-all;">
                                @context.User.FindFirst(ClaimTypes.NameIdentifier)?.Value
                            </MudText>
                        </MudStack>
                    </MudStack>
                </MudPaper>
            </MudStack>

            @* ---- Technical details (collapsible) ---- *@
            <MudExpansionPanels Elevation="0"
                                Style="border: 1px solid var(--mud-palette-lines-default); border-radius: 12px;">
                <MudExpansionPanel Text="Technische details" Dense="true">
                    <MudStack Spacing="2" Class="mt-1">
                        @foreach (var claim in context.User.Claims)
                        {
                            <MudPaper Elevation="0" Class="pa-3"
                                      Style="border: 1px solid var(--mud-palette-lines-default); border-radius: 10px;">
                                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="3">
                                    <div style="width: 36px; height: 36px; border-radius: 8px; background: var(--mud-palette-action-default); flex-shrink: 0; display: flex; align-items: center; justify-content: center;">
                                        <MudIcon Icon="@Icons.Material.Filled.Key" Style="color: var(--mud-palette-text-secondary); font-size: 1.1rem;" />
                                    </div>
                                    <MudStack Spacing="0" Style="min-width: 0;">
                                        <MudText Typo="Typo.caption" Color="Color.Secondary"
                                                 Style="font-family: monospace;">@claim.Type</MudText>
                                        <MudText Typo="Typo.body2" Style="word-break: break-all;">@claim.Value</MudText>
                                    </MudStack>
                                </MudStack>
                            </MudPaper>
                        }
                    </MudStack>
                </MudExpansionPanel>
            </MudExpansionPanels>

        </MudContainer>
    </Authorized>
    <NotAuthorized>
        <MudContainer MaxWidth="MaxWidth.Small" Class="mt-4">
            <MudAlert Severity="Severity.Warning" Elevation="0">Je moet ingelogd zijn om deze pagina te bekijken.</MudAlert>
            <MudButton Href="/Login?redirectUri=/profile" Variant="Variant.Filled" Color="Color.Primary" Class="mt-2">Inloggen</MudButton>
        </MudContainer>
    </NotAuthorized>
</AuthorizeView>
